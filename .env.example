# Public Firebase web config
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1234567890
NEXT_PUBLIC_FIREBASE_APP_ID=1:1234567890:web:yourappid

# Optional public feature flags
NEXT_PUBLIC_ENABLE_PWA=false
NEXT_PUBLIC_ENABLE_QA=false
NEXT_PUBLIC_APP_VERSION=

# QA access in production
QA_ROUTE_TOKEN=change_this_for_production

# Server-side Firebase Admin credentials
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Server-only access control
ALLOWED_EMAILS=user1@example.com,user2@example.com
ALLOW_ROLE_REASSIGN=false

# Optional distributed rate limiting for /api/client-errors
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional local smoke test overrides
SMOKE_HOST=127.0.0.1
SMOKE_PORT=
SMOKE_ENV_PATH=.env.local
SMOKE_INCLUDE_QA=false
SMOKE_ASSERT_QA_BLOCKED=false

# Optional dependency audit override
AUDIT_ALLOWLIST_FILE=security/audit-allowlist.json
