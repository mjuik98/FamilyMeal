rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDocPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function hasUserProfile() {
      return signedIn() && exists(userDocPath(request.auth.uid));
    }

    function currentUserRole() {
      return hasUserProfile() ? get(userDocPath(request.auth.uid)).data.role : null;
    }

    function validRole(role) {
      return role in ['아빠', '엄마', '딸', '아들'];
    }

    function validMealType(type) {
      return type in ['아침', '점심', '저녁', '간식'];
    }

    function validMealDescription(value) {
      return value is string
        && value.size() > 0
        && value.matches('.*\\S.*')
        && value.size() <= 300;
    }

    function validCommentText(value) {
      return value is string
        && value.size() > 0
        && value.size() <= 500;
    }

    function validImageUrl(value) {
      return value is string
        && value.size() > 0
        && value.size() <= 2048
        && value.matches('https?://.*');
    }

    function validKeywords(value) {
      return value is list
        && value.size() <= 80;
    }

    function validReactionMap(value) {
      return value is map
        && value.keys().hasOnly(['❤️', '👍', '😋', '👏', '🔥']);
    }

    function validReactionEmojiValue(value) {
      return value in ['❤️', '👍', '😋', '👏', '🔥'];
    }

    function validNotificationPreferences(value) {
      return value is map
        && value.keys().hasOnly(['browserEnabled', 'commentAlerts', 'reactionAlerts', 'replyAlerts'])
        && value.browserEnabled is bool
        && value.commentAlerts is bool
        && value.reactionAlerts is bool
        && value.replyAlerts is bool;
    }

    function hasNoSeedReactions(mealData) {
      return !('reactions' in mealData) || mealData.reactions.keys().size() == 0;
    }

    function hasValidParticipantList(mealData) {
      return mealData.userIds is list
        && mealData.userIds.size() > 0
        && mealData.userIds.hasOnly(['아빠', '엄마', '딸', '아들']);
    }

    function isMealParticipant(mealData) {
      return hasUserProfile()
        && (
          (mealData.userIds is list && mealData.userIds.hasAny([currentUserRole()]))
          || (mealData.userId is string && mealData.userId == currentUserRole())
        );
    }

    function isMealOwner(mealData) {
      return signedIn() && mealData.ownerUid is string && mealData.ownerUid == request.auth.uid;
    }

    function isLegacyMeal(mealData) {
      return !(mealData.ownerUid is string);
    }

    function canReadMeal(mealData) {
      return isMealParticipant(mealData);
    }

    function validMealDocument(mealData) {
      return mealData.keys().hasOnly([
          'ownerUid', 'userId', 'userIds', 'keywords', 'imageUrl', 'description', 'type', 'timestamp', 'commentCount', 'reactions'
        ])
        && mealData.ownerUid is string
        && mealData.ownerUid.size() > 0
        && hasValidParticipantList(mealData)
        && validMealDescription(mealData.description)
        && validMealType(mealData.type)
        && mealData.timestamp is timestamp
        && mealData.commentCount is int
        && mealData.commentCount >= 0
        && (!('imageUrl' in mealData) || validImageUrl(mealData.imageUrl))
        && (!('keywords' in mealData) || validKeywords(mealData.keywords))
        && (!('reactions' in mealData) || validReactionMap(mealData.reactions))
        && (!('userId' in mealData) || validRole(mealData.userId));
    }

    function canEditMealBody() {
      return validMealDocument(request.resource.data)
        && (
          isMealOwner(resource.data)
          || (isLegacyMeal(resource.data) && isMealParticipant(resource.data))
        )
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['commentCount', 'reactions'])
        && (
          request.resource.data.ownerUid == resource.data.ownerUid
          || (isLegacyMeal(resource.data) && request.resource.data.ownerUid == request.auth.uid)
        );
    }

    function validStoredCommentDocument(commentData) {
      return commentData.keys().hasOnly([
          'author', 'authorUid', 'text', 'parentId', 'mentionedAuthor', 'reactions', 'createdAt', 'updatedAt'
        ])
        && validRole(commentData.author)
        && commentData.authorUid is string
        && validCommentText(commentData.text)
        && (!('parentId' in commentData) || (commentData.parentId is string && commentData.parentId.size() > 0))
        && (!('mentionedAuthor' in commentData) || validRole(commentData.mentionedAuthor))
        && (!('reactions' in commentData) || validReactionMap(commentData.reactions))
        && commentData.createdAt is timestamp
        && commentData.updatedAt is timestamp;
    }

    function validUserProfile(profileData) {
      return profileData.keys().hasOnly(['uid', 'email', 'displayName', 'role', 'notificationPreferences'])
        && profileData.uid is string
        && profileData.uid == request.auth.uid
        && profileData.email is string
        && request.auth.token.email is string
        && profileData.email == request.auth.token.email
        && (!('displayName' in profileData) || profileData.displayName == null || profileData.displayName is string)
        && (profileData.role == null || validRole(profileData.role))
        && (!('notificationPreferences' in profileData) || validNotificationPreferences(profileData.notificationPreferences));
    }

    function validActivityDocument(activityData) {
      return activityData.keys().hasOnly(['type', 'actorUid', 'actorRole', 'mealId', 'commentId', 'reactionEmoji', 'preview', 'createdAt', 'readAt'])
        && activityData.type in ['meal-comment', 'comment-reply', 'meal-reaction', 'comment-reaction']
        && activityData.actorUid is string
        && validRole(activityData.actorRole)
        && activityData.mealId is string
        && activityData.preview is string
        && activityData.preview.size() > 0
        && activityData.preview.size() <= 300
        && activityData.createdAt is timestamp
        && (!('commentId' in activityData) || (activityData.commentId is string && activityData.commentId.size() > 0))
        && (!('reactionEmoji' in activityData) || validReactionEmojiValue(activityData.reactionEmoji))
        && (!('readAt' in activityData) || activityData.readAt == null || activityData.readAt is timestamp);
    }

    function sameNotificationPreferences(nextProfile, currentProfile) {
      return (
        !('notificationPreferences' in nextProfile)
        && !('notificationPreferences' in currentProfile)
      ) || (
        'notificationPreferences' in nextProfile
        && 'notificationPreferences' in currentProfile
        && nextProfile.notificationPreferences == currentProfile.notificationPreferences
      );
    }

    match /users/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;

      allow create: if signedIn()
        && request.auth.uid == uid
        && validUserProfile(request.resource.data)
        && request.resource.data.role == null;

      allow update: if signedIn()
        && request.auth.uid == uid
        && validUserProfile(request.resource.data)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role
        && sameNotificationPreferences(request.resource.data, resource.data);

      allow delete: if signedIn() && request.auth.uid == uid;

      match /activity/{activityId} {
        allow read: if signedIn()
          && request.auth.uid == uid
          && validActivityDocument(resource.data);

        allow create: if false;

        allow update: if signedIn()
          && request.auth.uid == uid
          && validActivityDocument(resource.data)
          && validActivityDocument(request.resource.data)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readAt']);

        allow delete: if false;
      }
    }

    match /meals/{mealId} {
      allow read: if canReadMeal(resource.data);

      allow create: if hasUserProfile()
        && validMealDocument(request.resource.data)
        && request.resource.data.ownerUid == request.auth.uid
        && hasNoSeedReactions(request.resource.data)
        && request.resource.data.userIds.hasAny([currentUserRole()]);

      allow update: if hasUserProfile() && canEditMealBody();

      allow delete: if false;

      match /comments/{commentId} {
        function parentMealPath() {
          return /databases/$(database)/documents/meals/$(mealId);
        }

        function parentMealData() {
          return get(parentMealPath()).data;
        }

        function canAccessParentMeal() {
          return exists(parentMealPath()) && canReadMeal(parentMealData());
        }

        allow read: if canAccessParentMeal() && validStoredCommentDocument(resource.data);

        allow create: if false;
        allow update: if false;
        allow delete: if false;
      }
    }
  }
}
